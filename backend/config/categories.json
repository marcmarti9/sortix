{
  "_comment": "Maps file extensions (lowercase, without dot) to a category. 'folder' is relative to the user's home directory. Feel free to add or change entries.",

  "categories": {
    "images": {
      "label": "Images",
      "icon": "image",
      "folder": "Pictures/Downloads",
      "extensions": ["jpg", "jpeg", "png", "gif", "webp", "heic", "heif", "bmp", "tiff", "svg", "raw"]
    },
    "videos": {
      "label": "Videos",
      "icon": "video",
      "folder": "Videos/Downloads",
      "extensions": ["mp4", "mkv", "mov", "avi", "webm", "flv", "wmv", "m4v"]
    },
    "music": {
      "label": "Music",
      "icon": "audio",
      "folder": "Music/Downloads",
      "extensions": ["mp3", "wav", "flac", "ogg", "m4a", "aac", "wma"]
    },
    "compressed": {
      "label": "Compressed",
      "icon": "archive",
      "folder": "Downloads/Compressed",
      "extensions": ["zip", "rar", "7z", "tar", "gz", "tgz", "bz2", "xz"]
    },
    "installers": {
      "label": "Installers",
      "icon": "installer",
      "folder": "Downloads/Installers",
      "extensions": ["exe", "msi", "deb", "rpm", "appimage", "dmg", "pkg", "apk"]
    },
    "documents": {
      "label": "Documents",
      "icon": "document",
      "folder": "Documents/Other",
      "extensions": ["pdf", "doc", "docx", "odt", "txt", "ppt", "pptx", "xls", "xlsx", "csv", "rtf"]
    },
    "other": {
      "label": "Other",
      "icon": "other",
      "folder": "Downloads/Other",
      "extensions": []
    }
  },

  "topic_matching": {
    "_comment": "Extensions whose content is analyzed to see if they belong to any of your custom Topics. Topics are defined from the UI, not here.",
    "content_extensions": ["pdf", "docx", "txt"]
  }
}
