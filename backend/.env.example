# Copia este fichero como .env si quieres cambiar algo (todo es opcional)

# Host/puerto donde escucha la interfaz web de Martix
HOST=127.0.0.1
PORT=5000

# Carpeta que se vigila. Por defecto es la carpeta "Downloads" del usuario.
# Descomenta y ajusta si tu carpeta de descargas esta en otro sitio:
# DOWNLOADS_DIR=/home/tu_usuario/Descargas

# Token de acceso a la API (cabecera X-Martix-Token). Opcional mientras
# HOST sea 127.0.0.1; OBLIGATORIO si expones Martix a la red (HOST=0.0.0.0),
# porque la API da acceso a nombres y movimientos de tus archivos.
# Genera uno con:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# MARTIX_TOKEN=

# LLM 100% local (Ollama) para nombrar carpetas de documentos que no encajan
# en ningun Tema ni subcategoria. Apagado por defecto: sin Ollama todo sigue
# funcionando igual con reglas y patrones. Requiere https://ollama.com y un
# modelo pequeno (ej. "ollama pull llama3.2").
# MARTIX_LLM=1
# MARTIX_LLM_URL=http://127.0.0.1:11434
# MARTIX_LLM_MODEL=llama3.2
