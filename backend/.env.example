# Copia este fichero como .env si quieres cambiar algo (todo es opcional)

# Host/puerto donde escucha la interfaz web de Sortix
HOST=127.0.0.1
PORT=5000

# Carpeta que se vigila. Por defecto es la carpeta "Downloads" del usuario.
# Descomenta y ajusta si tu carpeta de descargas esta en otro sitio:
# DOWNLOADS_DIR=/home/tu_usuario/Descargas
